{% extends 'base.html.twig' %}

{% block title %}Nouveau Post{% endblock %}

{% block body %}
<div class="app-layout">
    {{ include('partials/_sidebar.html.twig', ignore_missing = true) }}

    <main class="main-content flex justify-center">
        <div class="w-full max-w-2xl mt-10">
            
            <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 shadow-xl">
                <h1 class="text-2xl font-bold mb-6 text-white">Créer une publication</h1>

                {{ form_start(form) }}
                    
                    <div class="mb-4">
                        {{ form_label(form.discographie, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        {{ form_widget(form.discographie, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:ring-2 focus:ring-violet-500'}}) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.note, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        {{ form_widget(form.note, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white'}}) }}
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.commentaire, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        {{ form_widget(form.commentaire, {'attr': {'class': 'w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white min-h-[150px]'}}) }}
                    </div>

                    <div class="mb-6">
                        {{ form_label(form.imageFile, null, {'label_attr': {'class': 'block text-sm font-medium text-slate-300 mb-2'}}) }}
                        {{ form_widget(form.imageFile, {'attr': {'class': 'w-full text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-violet-50 file:text-violet-700 hover:file:bg-violet-100'}}) }}
                        {{ form_errors(form.imageFile) }}
                    </div>

                    <button type="submit" class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-3 px-6 rounded-xl transition duration-200">
                        Publier
                    </button>

                {{ form_end(form) }}
            </div>
        </div>
    </main>
</div>
{% endblock %}