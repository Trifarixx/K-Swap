{% extends 'base.html.twig' %}

{% block title %}K-Swap | Créer une publication
{% endblock %}

{% block body %}
	<div class="app-layout">

		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main
			class="main-content neon-page">

			{# En tête de la page #}
			<div class="page-header">
				<h1 class="page-title">Nouvelle Publication</h1>
				<p class="page-subtitle">Partage ton avis sur une musique ou un album avec la communauté.</p>
			</div>

			{# Formulaire PRINCIPAL de création de post #}
			{# N'oublie jamais le enctype pour l'upload de fichiers ! #}
			<form action="{{ path('app_post_new') }}" method="POST" id="post-form" enctype="multipart/form-data">

				<div
					class="post-creation-container">

					{# Panneau gauche : formulaire de création #}
					<div class="panel-box left-panel">
						<h3 class="panel-title">
							<span class="material-symbols-rounded">edit_square</span>
							Ton message
						</h3>

						<div class="form-group" style="margin-top: 15px;">
							<textarea name="commentaire" id="commentaire" rows="5" class="neon-input" placeholder="Que veux-tu dire sur ce son ? Écris ton avis détaillé ici..." required></textarea>
						</div>

						{# --- ZONE AJOUT MÉDIAS (Image ou Vidéo) --- #}
						<div class="media-addition-bar" style="margin-top: 15px;">
							<button type="button" class="btn-add-media" id="btn-trigger-media" title="Ajouter une image ou une vidéo">
								<span class="material-symbols-rounded">perm_media</span>
								<span style="margin-left: 8px;">Ajouter une image ou vidéo</span>
							</button>
						</div>

						{# Champ file caché (Accepte les images et les vidéos MP4/WebM) #}
						<input
						type="file" name="media_post" id="post-media-input" accept="image/png, image/jpeg, image/webp, image/gif, video/mp4, video/webm" style="display: none;">

						{# Zone de prévisualisation générée en JS #}
						<div id="media-preview-container" class="media-preview-box" style="display: none; margin-top: 15px; position: relative;"></div>
						{# ----------------------------------------- #}

						<button type="submit" class="neon-btn-submit auth-submit-btn" style="margin-top: 15px;">Publier la review</button>
					</div>

					{# Panneau droit : sélection de la musique #}
					<div class="panel-box right-panel">
						<h3 class="panel-title">
							<span class="material-symbols-rounded">library_music</span>
							Lier une musique
						</h3>

						<input type="text" id="music-search-input" class="search-input-lg" placeholder="Chercher un artiste, morceau, album...">

						<div class="search-results" id="search-results-container">
							<div class="empty-search-msg">
								<span class="material-symbols-rounded empty-search-icon">search</span>
								Tape pour chercher une musique...
							</div>
						</div>

						<input type="hidden" name="morceau_id" id="selected-morceau-id" required>

						<div id="selection-preview" style="display: none;">
							<p>Musique sélectionnée :</p>

							<div class="selection-box">
								<img id="selection-image" src="" alt="Cover">
								<strong id="selection-title"></strong>
							</div>

							<button type="button" onclick="cancelSelection()" class="btn-cancel-selection">
								Choisir une autre
							</button>
						</div>
					</div>
				</div>
			</form>
		</main>
	</div>

	<script>
		// ==========================================================
// 1. GESTION DES MÉDIAS LOCAUX (IMAGE & VIDÉO)
// ==========================================================
const mediaInput = document.getElementById('post-media-input');
const mediaPreviewContainer = document.getElementById('media-preview-container');
let currentObjectUrl = null;
// Pour vider la mémoire du navigateur

// Clic sur le bouton stylisé -> Ouvre l'explorateur de fichiers
document.getElementById('btn-trigger-media').addEventListener('click', () => {
mediaInput.click();
});

// Quand un fichier est sélectionné
mediaInput.addEventListener('change', function () {
const file = this.files[0];
if (! file) 
return;



// Sécurité : on libère l'ancienne URL si elle existe
if (currentObjectUrl) {
URL.revokeObjectURL(currentObjectUrl);
}

// Crée une URL locale temporaire pour l'aperçu
currentObjectUrl = URL.createObjectURL(file);
let mediaElementHTML = '';

/* Si c'est une image */
if (file.type.startsWith('image/')) {
mediaElementHTML = `<img src="${currentObjectUrl}" alt="Aperçu du média" class="preview-media-element">`;
}
/* Si c'est une vidéo */ else if (file.type.startsWith('video/')) {
mediaElementHTML = `<video src="${currentObjectUrl}" controls class="preview-media-element"></video>`;
}
/* Si c'est un format non supporté (sécurité front-end) */ else {
alert("Format de fichier non supporté. Utilise une image ou une vidéo MP4/WebM.");
removeMedia();
return;
}

// On injecte le média et le bouton de suppression
mediaPreviewContainer.innerHTML = `
                ${mediaElementHTML}
                <button type="button" class="btn-remove-media" onclick="removeMedia()" title="Retirer le média">
                    <span class="material-symbols-rounded">close</span>
                </button>
            `;
mediaPreviewContainer.style.display = 'inline-block';
});

// Fonction pour retirer le média
window.removeMedia = function () {
mediaInput.value = ""; // Vide le champ file
mediaPreviewContainer.innerHTML = ""; // Vide l'aperçu
mediaPreviewContainer.style.display = "none";
if (currentObjectUrl) {
URL.revokeObjectURL(currentObjectUrl); // Nettoie la mémoire
currentObjectUrl = null;
}
};

// ==========================================================
// 2. GESTION RECHERCHE MUSIQUE (AJAX)
// ==========================================================
const searchInput = document.getElementById('music-search-input');
const resultsContainer = document.getElementById('search-results-container');
const defaultImage = "{{ asset('img/logo_kpop.png') }}";

let typingTimer;
const doneTypingInterval = 400;

searchInput.addEventListener('keyup', function () {
clearTimeout(typingTimer);
let query = this.value.trim();

if (query.length > 2) {
resultsContainer.innerHTML = `<p class="status-msg-loading">Recherche en cours...</p>`;

typingTimer = setTimeout(() => {
fetch('/api/search/morceaux?q=' + encodeURIComponent(query)).then(response => {
if (!response.ok) 
throw new Error("Erreur serveur");



return response.json();
}).then(data => {
resultsContainer.innerHTML = '';

if (data.length === 0) {
resultsContainer.innerHTML = `<p class="empty-msg">Aucun morceau trouvé pour "${query}".</p>`;
return;
}

data.forEach(item => {
let imageUrl = item.pochette ? (item.pochette.startsWith('http') ? item.pochette : '/images/albums/' + item.pochette) : defaultImage;
let titrePropre = item.titre ? item.titre.replace(/'/g, "\\'") : 'Inconnu';
let artistePropre = item.artiste ? item.artiste.replace(/'/g, "\\'") : 'Inconnu';

resultsContainer.innerHTML += `
                                <div class="result-item" onclick="selectMusic(${
item.id
}, '${titrePropre} - ${artistePropre}', '${imageUrl}')">
                                    <img src="${imageUrl}" alt="Cover" class="result-cover" referrerpolicy="no-referrer">
                                    <div class="result-item-content">
                                        <div class="result-item-title">${
item.titre
}</div>
                                        <div class="result-item-artist">${
item.artiste
} • ${
item.album
}</div>
                                    </div>
                                </div>
                            `;
});
}).catch(err => {
console.error(err);
resultsContainer.innerHTML = `<p class="status-msg-error">Erreur lors de la recherche.</p>`;
});

}, doneTypingInterval);

} else {
resultsContainer.innerHTML = `
                    <div class="empty-search-msg">
                        <span class="material-symbols-rounded empty-search-icon">search</span>
                        Tape au moins 3 lettres pour chercher.
                    </div>
                `;
}
});

function selectMusic(id, title, imageUrl) {
document.getElementById('selected-morceau-id').value = id;
document.getElementById('selection-title').innerText = title;
document.getElementById('selection-image').src = imageUrl;

document.getElementById('selection-preview').style.display = 'block';
resultsContainer.style.display = 'none';
searchInput.value = '';
}

function cancelSelection() {
document.getElementById('selected-morceau-id').value = '';
document.getElementById('selection-preview').style.display = 'none';
resultsContainer.style.display = 'block';

resultsContainer.innerHTML = `
                <div class="empty-search-msg">
                    <span class="material-symbols-rounded empty-search-icon">search</span>
                    Recherche une nouvelle musique ci-dessus.
                </div>
            `;
}
	</script>
{% endblock %}
