{% extends 'base.html.twig' %}

{% block title %}K-Swipe | Discographie
{% endblock %}

{% block body %}
	<div class="app-layout">
		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main class="main-content">
			<div class="hero-card fade-in">
				<h1 class="hero-title">Le Meilleur de la Pop Asiatique
				</h1>
			</div>

			<div class="disco-grid mt-6">
				{% for groupe in groupes %}
					<a href="{{ path('app_groupe_show', {'id': groupe.id}) }}" class="disco-card fade-in" style="text-decoration: none; color: inherit; display: block;">

						<div class="disco-image-wrapper">
							{% if groupe.imageGrp %}
								{% set cleanUrl = groupe.imageGrp|trim %}
								{% if cleanUrl starts with 'http' or cleanUrl starts with '//' or cleanUrl starts with 'data:image' %}
									<img src="{{ cleanUrl }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" referrerpolicy="no-referrer">
								{% else %}
									<img src="{{ asset('uploads/groupes/' ~ cleanUrl) }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy">
								{% endif %}
							{% else %}
								<img src="{{ asset('img/logo_kpop.png') }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" style="object-fit: contain;">
							{% endif %}

							<div
								class="disco-overlay">
								{# Le bouton devient juste décoratif puisqu'on clique sur toute la carte #}
								<div class="btn-play">
									<span class="material-symbols-rounded">play_arrow</span>
								</div>
							</div>
						</div>

						<div class="disco-info">
							<h3 class="disco-title">{{ groupe.nomGroupe ?: groupe.nomScene }}
							</h3>

							<span class="disco-subtitle">
								{% if groupe.nomFanclub %}
									Fandom :
									{{ groupe.nomFanclub }}
								{% else %}
									Groupe K-Pop
								{% endif %}
							</span>
						</div>
					</a>
				{% else %}
					<div class="col-12">
						<p class="text-gray-400">Aucun groupe n'est disponible en base de données.</p>
					</div>
				{% endfor %}
			</div>
		</main>

		<aside class="right-panel"></aside>
	</div>
{% endblock %}
