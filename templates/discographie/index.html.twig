{% extends 'base.html.twig' %}

{% block title %}K-Swipe | Discographie
{% endblock %}

{% block body %}
	<div class="app-layout">

		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main
			class="main-content">

			{# En-tête de la page #}
			<div class="hero-card fade-in">
				<h1 class="hero-title">Le Meilleur de la Pop Asiatique</h1>
			</div>

			{# Grille des groupes #}
			<div
				class="disco-grid mt-6">

				{# On parcourt les groupes #}
				{% for groupe in groupes %}

					{# Carte Groupe #}
					{# Redirige vers la page d'affichage spécifique d'un groupe #}
						<a
						href="{{ path('app_groupe_show', {'id': groupe.id}) }}" class="disco-card fade-in" style="text-decoration: none; color: inherit; display: block;"> {# Image du groupe #}
						<div
							class="disco-image-wrapper">

							{# Vérifie si une image de groupe existe #}
							{% if groupe.imageGrp %}
								{% set cleanUrl = groupe.imageGrp|trim %}

								{# Image externe (Scrapping) #}
								{% if cleanUrl starts with 'http' or cleanUrl starts with '//' or cleanUrl starts with 'data:image' %}
									<img
									src="{{ cleanUrl }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" referrerpolicy="no-referrer">
									{# Image locale (Uploadée) #}
								{% else %}
									<img src="{{ asset('uploads/groupes/' ~ cleanUrl) }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy">
								{% endif %}

								{# Image par défaut #}
							{% else %}
								<img src="{{ asset('img/logo_kpop.png') }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" style="object-fit: contain;">
							{% endif %}

							<div class="disco-overlay">
								<div class="btn-play">
									<span class="material-symbols-rounded">play_arrow</span>
								</div>
							</div>
						</div>

						{# Informations du groupe #}
						<div
							class="disco-info">
							{# Titre principal (Nom du groupe ou Nom de scène) #}
							<h3 class="disco-title">{{ groupe.nomGroupe ?: groupe.nomScene }}</h3>

							{# Sous-titre (Fandom ou catégorie par défaut) #}
							<span class="disco-subtitle">
								{% if groupe.nomFanclub %}
									Fandom :
									{{ groupe.nomFanclub }}
								{% else %}
									Groupe K-Pop
								{% endif %}
							</span>
						</div>

					</a>

					{# cas où aucun groupe n'est trouvé #}
				{% else %}
					<div class="col-12">
						<p class="text-gray-400">Aucun groupe n'est disponible en base de données.</p>
					</div>
				{% endfor %}

			</div>
		</main>

		<aside class="right-panel"></aside>

	</div>
{% endblock %}
