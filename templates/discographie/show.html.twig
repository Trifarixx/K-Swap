{% extends 'base.html.twig' %}

{% block title %}K-Swap | Albums de
	{{ groupe.nomGroupe ?: groupe.nomScene }}
{% endblock %}

{% block body %}
	<div class="app-layout">
		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main class="main-content">
			<div class="hero-card fade-in">
				<h1 class="hero-title">Discographie :
					{{ groupe.nomGroupe ?: groupe.nomScene }}</h1>
			</div>

			<div class="disco-grid mt-6">
				{% for album in groupe.discographies %}

					{# Le lien pointe vers notre nouvelle page Album #}
					<a href="{{ path('app_album_show', {'id': album.id}) }}" class="disco-card fade-in" style="text-decoration: none; color: inherit; display: block;">

						<div class="disco-image-wrapper">
							{% if album.pochette %}
								{% set cleanUrl = album.pochette|trim %}
								{% if cleanUrl starts with 'http' or cleanUrl starts with '//' %}
									<img src="{{ cleanUrl }}" alt="{{ album.titre }}" loading="lazy" referrerpolicy="no-referrer">
								{% else %}
									<img src="{{ asset('images/albums/' ~ cleanUrl) }}" alt="{{ album.titre }}" loading="lazy">
								{% endif %}
							{% else %}
								<img src="{{ asset('img/logo_kpop.png') }}" alt="{{ album.titre }}" loading="lazy" style="object-fit: contain;">
							{% endif %}

							<div class="disco-overlay">
								<div class="btn-play">
									<span class="material-symbols-rounded">play_arrow</span>
								</div>
							</div>
						</div>

						<div class="disco-info">
							<h3 class="disco-title">{{ album.titre }}</h3>
							<span class="disco-subtitle">
								{{ album.dateSortie ? album.dateSortie|date('Y') : 'Année inconnue' }}
							</span>
						</div>

					</a>
				{% else %}
					<div class="col-12">
						<p class="text-gray-400">Aucun album disponible pour ce groupe.</p>
					</div>
				{% endfor %}
			</div>
		</main>

		<aside class="right-panel"></aside>
	</div>
{% endblock %}
