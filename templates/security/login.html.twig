{% extends 'base.html.twig' %}

{% block title %}KSwipe - Connexion
{% endblock %}

{% block body %}
	<div class="auth-container">
		<div class="auth-card">

			<div class="auth-icon-wrapper">
				<span class="material-symbols-rounded icon-accent">lock</span>
			</div>

			<h1 class="auth-title">Connexion</h1>
			<p class="auth-subtitle">Content de te revoir !</p>

			<form method="post">
				{% if error %}
					<div class="auth-error-msg">
						{{ error.messageKey|trans(error.messageData, 'security') }}
					</div>
				{% endif %}

				<div class="form-group">
					<label for="username" class="form-label">Email</label>
					<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-input" autocomplete="email" required autofocus placeholder="ton@email.com">
				</div>

				<div class="form-group">
					<label for="password" class="form-label">Mot de passe</label>
					<input type="password" name="_password" id="password" class="form-input" autocomplete="current-password" required placeholder="••••••••">
				</div>

				<div class="form-group">
					<label class="custom-checkbox">
						<input type="checkbox" name="_remember_me">
						<span>Se souvenir de moi</span>
					</label>
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				<button type="submit" class="btn btn-primary auth-submit-btn">
					Se connecter
				</button>

				<div class="auth-footer">
					Pas encore de compte ?
					<a href="{{ path('app_register') }}" class="auth-link">S'inscrire</a>
				</div>
			</form>
		</div>
	</div>
{% endblock %}
