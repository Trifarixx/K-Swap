{% extends 'base.html.twig' %}

{% block title %}Connexion | K-Swap{% endblock %}



{% block body %}
<div class="auth-container">
    <div class="auth-card">
        
        <div style="text-align: center; margin-bottom: 1rem;">
            <span class="material-symbols-rounded" style="font-size: 48px; color: var(--accent);">lock</span>
        </div>

        <h1 class="auth-title">Connexion</h1>
        <p class="auth-subtitle">Content de te revoir !</p>

        <form method="post">
            {% if error %}
                <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; color: #ef4444; padding: 0.75rem; border-radius: 12px; margin-bottom: 1.5rem; text-align: center; font-size: 0.9rem;">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <div class="form-group">
                <label for="username" class="form-label">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-input" autocomplete="email" required autofocus placeholder="ton@email.com">
            </div>

            <div class="form-group">
                <label for="password" class="form-label">Mot de passe</label>
                <input type="password" name="_password" id="password" class="form-input" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <div class="form-group">
                <label class="custom-checkbox">
                    <input type="checkbox" name="_remember_me">
                    <span>Se souvenir de moi</span>
                </label>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
                Se connecter
            </button>

            <div class="auth-footer">
                Pas encore de compte ? <a href="{{ path('app_register') }}" class="auth-link">S'inscrire</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}