{% extends 'base.html.twig' %}

{% block title %}
	K-Swipe | Découvrir des groupes
{% endblock %}

{% block body %}
	<div class="app-layout">
		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main class="main-content">
			<div class="hero-card fade-in">
				<h1 class="hero-title">Découvre de nouveaux groupes</h1>
				<p class="text-gray-400 mt-2">Explore les talents et groupes de la scène asiatique</p>
			</div>

			{# Grille des groupes #}
			<div
				class="disco-grid mt-6">

				{# On vérifie d'abord qu'on a bien des groupes à afficher depuis la base de données #}
				{% if groupes is not empty %}

					{# On génère une carte pour chaque groupe trouvé en BDD #}
					{% for groupe in groupes %}

						{# carte groupe #}
						{# Le lien <a> englobe toute la carte et mène vers la page détaillée du groupe visé #}
							<a
							href="{{ path('app_artiste_groupe', {'id': groupe.id}) }}" class="disco-card fade-in" style="text-decoration: none; color: inherit; display: block;"> {# gestion de l'image du groupe #}
							<div
								class="disco-image-wrapper">

								{# Est-ce que le groupe possède une image renseignée ? #}
								{% if groupe.imageGrp %}

									{# On nettoie l'URL (enlève les espaces invisibles au début/fin avec le filtre 'trim') #}
									{% set cleanUrl = groupe.imageGrp|trim %}

									{# S'agit-il d'un lien internet (venant du Scrapping) ou d'un upload local ? #}
									{% if cleanUrl starts with 'http' or cleanUrl starts with '//' or cleanUrl starts with 'data:image' %}
										{# Image web : on ajoute 'referrerpolicy="no-referrer"' pour éviter le blocage #}
										<img src="{{ cleanUrl }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" referrerpolicy="no-referrer">
									{% else %}
										{# Image locale : on pointe vers le dossier public/uploads/groupes/ #}
										<img src="{{ asset('uploads/groupes/' ~ cleanUrl) }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy">
									{% endif %}

									{# Si le groupe n'a vraiment aucune image, on met le logo par défaut #}
								{% else %}
									<img src="{{ asset('img/logo_kpop.png') }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" style="object-fit: contain;">
								{% endif %}
							</div>

							{# Informations groupe #}
							<div
								class="disco-info">

								{# Affiche le nom du groupe (s'il est vide, on tente d'afficher un nom de scène en secours) #}
								<h3 class="disco-title">
									{{ groupe.nomGroupe ?: groupe.nomScene }}</h3>

								{# Affiche le nom du fanclub en sous-titre #}
								<span class="disco-subtitle">
									{% if groupe.nomFanclub %}
										Fandom :
										{{ groupe.nomFanclub }}
									{% else %}
										Groupe K-Pop
									{% endif %}
								</span>
							</div>
						</a>
					{% endfor %}

					{# si aucun groupe en BDD n'est trouvé#}
				{% else %}
					<p class="text-gray-400">Aucun groupe disponible</p>
				{% endif %}
			</div>
		</main>

		<aside class="right-panel"></aside>
	</div>
{% endblock %}
