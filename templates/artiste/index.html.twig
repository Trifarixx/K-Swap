{% extends 'base.html.twig' %}

{% block title %}K-Swipe| Découvrir des groupes{% endblock %}

{% block body %}
<div class="app-layout">
    {% include 'header.html.twig' %}
    {% include 'sidebar.html.twig' %}

    <main class="main-content">
        <div class="hero-card fade-in">
            <h1 class="hero-title">Découvre de nouveaux groupes 🎧</h1>
            <p class="text-gray-400 mt-2">Explore les talents et groupes de la scène asiatique</p>
        </div>    

        <div class="disco-grid mt-6">
            {% if groupes is not empty %}
                {% for groupe in groupes %}
                    <a href="{{ path('app_artiste_groupe', {'id': groupe.id}) }}" class="disco-card fade-in" style="text-decoration: none; color: inherit; display: block;">
                        <div class="disco-image-wrapper">
                            {% if groupe.imageGrp %}
                                {% set cleanUrl = groupe.imageGrp|trim %}
                                {% if cleanUrl starts with 'http' or cleanUrl starts with '//' or cleanUrl starts with 'data:image' %}
                                    <img src="{{ cleanUrl }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" referrerpolicy="no-referrer">
                                {% else %}
                                    <img src="{{ asset('uploads/groupes/' ~ cleanUrl) }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy">
                                {% endif %}
                            {% else %}
                                <img src="{{ asset('img/logo_kpop.png') }}" alt="{{ groupe.nomGroupe ?: groupe.nomScene }}" loading="lazy" style="object-fit: contain;">
                            {% endif %}
                        </div>

                        <div class="disco-info">
                            <h3>{{ groupe.nomGroupe ?: groupe.nomScene }}</h3>
                            <span>
                                {% if groupe.nomFanclub %}
                                    Fandom : {{ groupe.nomFanclub }}
                                {% else %}
                                    Groupe K-Pop
                                {% endif %}
                            </span>
                        </div>
                    </a>
                {% endfor %}
            {% else %}
                <p class="text-gray-400">Aucun groupe disponible</p>
            {% endif %}
        </div>
    </main>

    <aside class="right-panel"></aside>
</div>
{% endblock %}