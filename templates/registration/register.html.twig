{% extends 'base.html.twig' %}

{% block title %}KSwipe - Inscription
{% endblock %}

{% block body %}
	<div class="auth-container">
		<div class="auth-card">
			<div class="auth-icon-wrapper">
				<span class="material-symbols-rounded icon-primary">album</span>
			</div>

			<h1 class="auth-title">Bienvenue</h1>
			<p class="auth-subtitle">Crée ton compte et rejoins la communauté.</p>

			{{ form_errors(registrationForm) }}

			{{ form_start(registrationForm) }}

			<div class="form-group">
				{{ form_label(registrationForm.pseudonyme, 'Ton Pseudo', {'label_attr': {'class': 'form-label'}}) }}
				{{ form_widget(registrationForm.pseudonyme, {'attr': {'class': 'form-input', 'placeholder': 'Ex: Twice4Life'}}) }}
				<div class="form-error">
					{{ form_errors(registrationForm.pseudonyme) }}
				</div>
			</div>

			<div class="form-group">
				{{ form_label(registrationForm.email, 'Ton Email', {'label_attr': {'class': 'form-label'}}) }}
				{{ form_widget(registrationForm.email, {'attr': {'class': 'form-input', 'placeholder': 'Ex: fan@kpop.com'}}) }}
				<div class="form-error">
					{{ form_errors(registrationForm.email) }}
				</div>
			</div>

			<div class="form-group">
				{{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
				{{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'form-input', 'placeholder': '••••••••'}}) }}
				<div class="form-error">
					{{ form_errors(registrationForm.plainPassword) }}
				</div>
			</div>

			<div class="form-group">
				<label class="custom-checkbox">
					{{ form_widget(registrationForm.agreeTerms) }}
					<span>J'accepte les conditions d'utilisation</span>
				</label>
			</div>

			<button type="submit" class="btn btn-primary auth-submit-btn">
				Créer mon compte
			</button>

			{{ form_end(registrationForm) }}

			<div class="auth-footer">
				Déjà membre ?
				<a href="{{ path('app_login') }}" class="auth-link">Se connecter</a>
			</div>
		</div>
	</div>
{% endblock %}
