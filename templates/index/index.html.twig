{% extends 'base.html.twig' %}

{% block title %}K-World | Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Lien vers ton fichier CSS -->
    <link rel="stylesheet" href="{{ asset('css/Styles.css') }}">
    <!-- Import des icônes Google Material Symbols (arrondies) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
{% endblock %}

{% block body %}
<div class="app-layout">
    {% include 'header.html.twig' %}
    {% include 'sidebar.html.twig' %}


    <!-- 3. MAIN CONTENT (Le cœur du site) -->
    <main class="main-content">
    <div class="hero-card">
    </div>

    <div class="feed-container"
             data-controller="infinite-scroll"
             data-infinite-scroll-page-value="{{ current_page }}"
             data-infinite-scroll-total-value="{{ pages_total }}"
             data-infinite-scroll-url-value="{{ path('app_home') }}">

            <div data-infinite-scroll-target="container">
                {% include 'index/_feed_items.html.twig' %}
            </div>
        </div>
    </main>

    <!-- 4. RIGHT PANEL  -->
    <aside class="right-panel">

    </aside>

</div>
{% endblock %}