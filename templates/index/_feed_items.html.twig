{% for avis in avis_list %}

	{# carte avis #}
	<article
		class="feed-card fade-in mb-6">

		{# en tête du post #}
		<div
			class="feed-header">

			{# -- Infos de l'utilisateur -- #}
			<div
				class="user-info">

				{# Gestion de l'avatar utilisateur #}
				{% if avis.user.avatar %}
					{# Si l'utilisateur a uploadé une photo de profil #}
					<img src="{{ asset(avis.user.avatar) }}" alt="{{ avis.user.pseudonyme }}" class="user-avatar">
				{% else %}
					{# On affiche un rond de couleur avec la 1ère lettre de son pseudo en majuscule #}
					<div class="user-avatar-placeholder">{{ avis.user.pseudonyme|first|upper }}</div>
				{% endif %}

				{# Nom et date du post #}
				<div>
					<h4 class="user-name">{{ avis.user.pseudonyme }}</h4>
					{# Formatage de la date #}
					<span class="post-date">{{ avis.dateCreation|date('d M Y à H:i') }}</span>
				</div>
			</div>

			{# Badge de la Note #}
			{# On ne l'affiche que si l'utilisateur a laissé une note #}
			{% if avis.note %}
				<div class="rating-badge">
					<span class="material-symbols-rounded">star</span>
					<span>{{ avis.note }}/5</span>
				</div>
			{% endif %}

		</div>

		<div class="feed-content">
			{# 1. Le texte du post #}
			{# On utilise une div au lieu d'un <p> pour éviter les conflits si ton éditeur ajoute déjà des <p> en HTML #}
				<div class="post-text"> {{ avis.commentaire|raw }}
			</div>

			{# 2. L'image uploadée par l'utilisateur #}
			{% if avis.image and avis.image|trim is not empty %}
				<div class="feed-media-container">
					<img src="{{ asset('uploads/posts/' ~ avis.image) }}" alt="Image du post" class="feed-media" onerror="this.onerror=null; this.closest('.feed-media-container').style.display='none';">
				</div>
			{% endif %}

		</div>

		{# Si cet avis est rattaché à une discographie (album), on affiche une jolie carte intégrée en bas du post #}
		{% if avis.discographie %}

			{# La carte de l'album est entièrement cliquable et renvoie vers la page de l'album #}
			<a href="{{ path('app_album_show', {'id': avis.discographie.id}) }}" class="feed-album-link">

				<div
					class="feed-album">

					{# -- Logique de la pochette (identique aux autres vues) -- #}
					{% set cleanPochette = avis.discographie.pochette ? avis.discographie.pochette|trim : '' %}
					{% set pochetteUrl = cleanPochette ? (cleanPochette starts with 'http' or cleanPochette starts with '//' ? cleanPochette : asset('images/albums/' ~ cleanPochette)) : asset('img/logo_kpop.png') %}

					<div class="album-blur-bg" style="background-image: url('{{ pochetteUrl }}');"></div>

					{# Contenu de la petite carte album #}
					<div
						class="album-mini">

						{# Image de la pochette #}
						<img
						src="{{ pochetteUrl }}" alt="Cover" referrerpolicy="no-referrer">

						{# Détails du morceau/album #}
						<div
							class="album-details">

							{# Si l'avis cible un morceau précis de l'album, on affiche son titre en premier #}
							{% if avis.morceau %}
								<span class="track-title">{{ avis.morceau.titre }}</span>
							{% endif %}

							{# Affichage du titre de l'album et de l'artiste #}
							<span class="album-title">{{ avis.discographie.titre }}</span>
							<span class="album-artist">{{ avis.discographie.artiste.nomScene }}</span>
						</div>
					</div>

				</div>
			</a>

			
		{% endif %}

		<div class="feed-comments">
			<h4 class="comments-title">
				Commentaires
				<span class="comments-count">{{ avis.commentaires|length }}</span>
			</h4>

			{% if avis.commentaires|length > 0 %}
				<ul class="comments-list">
					{% for commentaire in avis.commentaires %}
						<li class="comment-item">
							{% if commentaire.user.avatar %}
								<img src="{{ asset(commentaire.user.avatar) }}" alt="{{ commentaire.user.pseudonyme }}" class="comment-avatar">
							{% else %}
								<div class="comment-avatar-placeholder">{{ commentaire.user.pseudonyme|first|upper }}</div>
							{% endif %}
							<div class="comment-body">
								<div class="comment-header">
									<span class="comment-author">{{ commentaire.user.pseudonyme }}</span>
									<span class="comment-date">{{ commentaire.dateCreation|date('d/m/Y H:i') }}</span>
								</div>
								<p class="comment-content">{{ commentaire.contenu|nl2br }}</p>
							</div>
						</li>
					{% endfor %}
				</ul>
			{% else %}
				<p class="comments-empty">Aucun commentaire pour le moment. Soyez le premier !</p>
			{% endif %}

			<form method="post" action="{{ path('app_avis_commenter', {'id': avis.id}) }}" class="comment-form">
				<textarea 
					name="contenu" 
					class="comment-textarea" 
					rows="2" 
					required 
					placeholder="Écrire un commentaire..."
					maxlength="1000"></textarea>
				<button type="submit" class="comment-submit">Publier</button>
			</form>
		</div>

	</article>

{% endfor %}
