{# On enveloppe cette page dans un cadre avec un ID unique (ex: feed-page-1) #}
<turbo-frame
	id="feed-page-{{ current_page }}">

	{# 1. Les articles de la page actuelle #}
	{% for avis in avis_list %}
		<article class="feed-card fade-in mb-6">
			<div class="feed-header">
				<div class="user-info">
					<h4 class="user-name">{{ avis.user.pseudonyme }}</h4>
					<span class="post-date">{{ avis.dateCreation|date('d/m/Y') }}</span>
				</div>
				{% if avis.note %}
					<div class="rating-badge">{{ avis.note }}/5</div>
				{% endif %}
			</div>

			<div class="feed-content">
				<p>{{ avis.commentaire }}</p>
				{% if avis.image %}
					<div class="post-image mt-3">
						<img src="{{ asset('uploads/posts/' ~ avis.image) }}" alt="Post">
					</div>
				{% endif %}
			</div>
		</article>
	{% endfor %}

	{# 2. Le cadre "Lazy" pour la page SUIVANTE #}
	{% if current_page < pages_total %}
		<div
			class="loading-trigger py-4 text-center">
			{# 
			               C'est ICI l'astuce : loading="lazy".
			               Turbo ne chargera cette URL que lorsque cet élément sera visible à l'écran.
			            #}
			<turbo-frame id="feed-page-{{ current_page + 1 }}" src="{{ path('app_home', {'page': current_page + 1}) }}" loading="lazy" target="_top">

				<div class="loading-spinner" style="color: var(--primary);">
					<span class="material-symbols-rounded fa-spin">refresh</span>
					Chargement de la suite...
				</div>

			</turbo-frame>
		</div>
	{% endif %}

</turbo-frame>
