{% for avis in avis_list %}
	<article
		class="feed-card fade-in mb-6">
		{# 1. En-tête du post (Utilisateur + Note) #}
		<div class="feed-header">
			<div class="user-info">
				{% if avis.user.avatar %}
					<img src="{{ asset(avis.user.avatar) }}" alt="{{ avis.user.pseudonyme }}" class="user-avatar">
				{% else %}
					<div class="user-avatar-placeholder">{{ avis.user.pseudonyme|first|upper }}</div>
				{% endif %}
				<div>
					<h4 class="user-name">{{ avis.user.pseudonyme }}</h4>
					<span class="post-date">{{ avis.dateCreation|date('d M Y à H:i') }}</span>
				</div>
			</div>
			{% if avis.note %}
				<div class="rating-badge">
					<span class="material-symbols-rounded">star</span>
					<span>{{ avis.note }}/5</span>
				</div>
			{% endif %}
		</div>

		{# 2. contenu du post(Commentaire + Image uploadée) #}
		<div class="feed-content">
			<p>{{ avis.commentaire }}</p>

			{# Affiche l'image uploadée seulement si ce n'est pas un avis musical #}
			{% if avis.image and not avis.morceau %}
				<div class="post-image mb-4 rounded-xl overflow-hidden mt-3">
					<img src="{{ asset('uploads/posts/' ~ avis.image) }}" alt="Post image" class="w-full h-auto object-cover">
				</div>
			{% endif %}
		</div>

		{# Album et Morceau #}
		{% if avis.discographie %}
			<a
				href="{{ path('app_album_show', {'id': avis.discographie.id}) }}" style="text-decoration: none; color: inherit; display: block;">

				{# Conteneur principal #}
				<div
					class="feed-album" style="position: relative; overflow: hidden; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); margin-top: 16px; padding: 16px; transition: transform 0.2s; cursor: pointer;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">

					{# lien image #}
					{% set cleanPochette = avis.discographie.pochette ? avis.discographie.pochette|trim : '' %}
					{% set pochetteUrl = cleanPochette ? (cleanPochette starts with 'http' or cleanPochette starts with '//' ? cleanPochette : asset('images/albums/' ~ cleanPochette)) : asset('img/logo_kpop.png') %}

					<div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background-image: url('{{ pochetteUrl }}'); background-size: cover; background-position: center; filter: blur(40px) brightness(0.3) saturate(1.5); z-index: 0; pointer-events: none;"></div>

					<div class="album-mini" style="position: relative; z-index: 1; display: flex; align-items: center; gap: 15px;">

						<img src="{{ pochetteUrl }}" alt="Cover" referrerpolicy="no-referrer" style="width: 60px; height: 60px; border-radius: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.5); object-fit: cover;">

						<div class="album-details" style="display: flex; flex-direction: column;">
							{% if avis.morceau %}
								<span class="track-title" style="font-weight: bold; color: #FF6DB3; font-size: 14px; margin-bottom: 4px;">{{ avis.morceau.titre }}</span>
							{% endif %}

							<span class="album-title" style="font-weight: 600; color: white; font-size: 16px; margin-bottom: 2px;">{{ avis.discographie.titre }}</span>
							<span class="album-artist" style="color: #ccc; font-size: 13px;">{{ avis.discographie.artiste.nomScene }}</span>
						</div>
					</div>
				</div>
			</a>
		{% endif %}

	</article>
{% endfor %}
