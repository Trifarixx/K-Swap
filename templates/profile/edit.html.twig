{% extends 'base.html.twig' %}

{% block title %}KSwap | Modifier mon Profil
{% endblock %}

{% block body %}
	<div class="app-layout">

		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main
			class="main-content">

			{# En tete de page #}
			<div class="page-header fade-in">
				<h1 class="page-title">Modifier mon Profil</h1>
				<p class="page-subtitle">Mets à jour tes informations personnelles et ton avatar.</p>
			</div>

			{# Panneau de modification du profil #}
			<div class="panel-box fade-in" style="animation-delay: 0.1s; max-width: 600px; margin: 0 auto;">

				<h3 class="panel-title">
					<span class="material-symbols-rounded">manage_accounts</span>
					Tes informations
				</h3>

				{{ form_start(form) }}

				{# Champ : Pseudo #}
				<div class="form-group">
					{{ form_label(form.pseudonyme) }}
					{{ form_widget(form.pseudonyme) }}
					<div class="form-error">
						{{ form_errors(form.pseudonyme) }}
					</div>
				</div>

				{# Champ : Email #}
				<div class="form-group">
					{{ form_label(form.email) }}
					{{ form_widget(form.email) }}
					<div class="form-error">
						{{ form_errors(form.email) }}
					</div>
				</div>

				{# Champ : Image de profil #}
				<div class="form-group">
					{{ form_label(form.avatarFile) }}

					<div
						class="flex items-center gap-4 mt-2 mb-4">
						{# Aperçu de l'avatar actuel #}
						{% if app.user.avatar %}
							<img src="{{ asset(app.user.avatar) }}" alt="{{ app.user.pseudonyme }}" class="user-avatar" style="width: 60px; height: 60px; border-radius: 50%; object-fit: cover;">
						{% else %}
							<div class="user-avatar-placeholder" style="width: 60px; height: 60px; border-radius: 50%; background: linear-gradient(135deg, var(--primary), var(--accent)); font-size: 1.5rem; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
								{{ app.user.pseudonyme|first|upper }}
							</div>
						{% endif %}

						{# Upload de la pp #}
						<div class="flex-grow">
							{{ form_widget(form.avatarFile) }}
							<p class="help-text" style="color: rgba(255,255,255,0.4); font-size: 0.8rem; margin-top: 5px;">JPEG, PNG, WEBP</p>
						</div>
					</div>

					<div class="form-error">
						{{ form_errors(form.avatarFile) }}
					</div>
				</div>

				{# Modification du mot de passe #}
				<div style="background: rgba(0, 0, 0, 0.2); border: 1px solid rgba(255, 255, 255, 0.05); padding: 20px; border-radius: 12px; margin-bottom: 24px; margin-top: 30px;">
					<h4 style="color: var(--accent); margin-bottom: 5px; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
						<span class="material-symbols-rounded">lock_reset</span>
						Sécurité
					</h4>
					<p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">Laisse ces champs vides si tu ne souhaites pas modifier ton mot de passe.</p>

					<div class="form-group">
						{{ form_label(form.oldPassword) }}
						{{ form_widget(form.oldPassword) }}
						<div class="form-error">{{ form_errors(form.oldPassword) }}</div>
					</div>

					<div class="form-group">
						{{ form_label(form.newPassword.first) }}
						{{ form_widget(form.newPassword.first) }}
						<div class="form-error">{{ form_errors(form.newPassword.first) }}</div>
					</div>

					<div class="form-group" style="margin-bottom: 0;">
						{{ form_label(form.newPassword.second) }}
						{{ form_widget(form.newPassword.second) }}
						<div class="form-error">{{ form_errors(form.newPassword.second) }}</div>
					</div>
				</div>

				{# Bouton d'enregistrement #}
				<button type="submit" class="neon-btn-submit auth-submit-btn">
					Enregistrer les modifications
				</button>

				{{ form_end(form) }}

				{# Annulation #}
				<div class="auth-footer" style="text-align: center; margin-top: 20px; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 20px;">
					<a href="{{ path('app_profile') }}" class="auth-link" style="color: var(--text-muted); text-decoration: none; font-size: 0.9rem;">Annuler et revenir au profil</a>
				</div>

			</div>
		</main>

		<aside class="right-panel"></aside>
	</div>
{% endblock %}
