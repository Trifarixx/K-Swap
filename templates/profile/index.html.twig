{% extends 'base.html.twig' %}

{% block title %}K-Swap | Mon Profil
{% endblock %}

{% block body %}
	<div class="app-layout">

		{% include 'header.html.twig' %}
		{% include 'sidebar.html.twig' %}

		<main
			class="main-content">

			{# En-tête de profil (Informations Utilisateur) #}
			<div class="profile-header-card fade-in">
				<div class="profile-header-content">

					{# Avatar #}
					{# On utilise app.user qui représente l'utilisateur actuellement connecté #}
						{% if app.user.avatar %}
						<img src="{{ asset(app.user.avatar) }}" alt="{{ app.user.pseudonyme }}" class="profile-avatar-large">
					{% else %}
						{# On prend la première lettre du pseudo (|first) et on la met en majuscule (|upper) #}
						<div class="profile-avatar-placeholder-large">{{ app.user.pseudonyme|first|upper }}</div>
					{% endif %}

					{# Infos & Statistiques #}
					<div
						class="profile-info">
						{# Pseudo et Email #}
						<h1>{{ app.user.pseudonyme }}</h1>
						<span class="profile-email">{{ app.user.email }}</span>

						{# Badge de statistiques #}
						<div class="profile-stats">
							<div class="stat-badge">
								<span class="material-symbols-rounded">reviews</span>
								{# On compte combien d'avis sont dans le tableau avec le filtre |length #}
								{{ avis_list|length }}
								Avis publiés
							</div>
						</div>
					</div>

					{# Modification #}
					<div>
						{# Lien vers le formulaire d'édition qu'on a commenté juste avant #}
						<a href="{{ path('app_profile_edit') }}" class="btn btn-glass">
							<span class="material-symbols-rounded">edit</span>
							Modifier
						</a>
					</div>

				</div>
			</div>

			{# Liste des avis publiés par l'utilisateur #}
			<div class="section-header fade-in" style="animation-delay: 0.1s;">
				<h2 class="section-title">Mes dernières publications</h2>
			</div>

			<div
				id="feed-container">

				{# Cas où l'utilisateur n'a encore rien publié #}
				{% if avis_list is empty %}

					{# Message d'incitation avec un bouton pour l'encourager à poster #}
					<div class="empty-msg" style="background: rgba(255,255,255,0.02); border-radius: 16px; border: 1px dashed rgba(255,255,255,0.1);">
						<span class="material-symbols-rounded" style="font-size: 48px; opacity: 0.5; display: block; margin-bottom: 10px;">speaker_notes_off</span>
						Tu n'as pas encore publié d'avis.
						<br><br>
						<a href="{{ path('app_post_new') }}" class="btn btn-primary">Créer mon premier post</a>
					</div>

					{# Cas où l'utilisateur a des publications #}
				{% else %}

					{# Au lieu de réécrire toute la boucle d'affichage, on inclut intelligemment le même fichier qui gère le fil d'actualité ! #}
					{% include 'index/_feed_items.html.twig' %}

				{% endif %}
			</div>

		</main>

		<aside class="right-panel"></aside>

	</div>
{% endblock %}
